# Copy to .env for local Docker dev. .env is gitignored — never commit it.
# For prod, swap REDIS_URL for your Redis Cloud URL (rediss://...) and
# set COOKIE_SECURE=true, COOKIE_SAMESITE=none.

REDIS_URL=redis://redis:6379/0
JOB_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
SESSION_COOKIE_NAME=sid
SESSION_TTL_SECONDS=86400
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=            # leave unset for localhost
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# auto, cpu, mps, cuda, cuda:<index>, nvidia, rocm, or amd
ML_DEVICE=auto
ENVIRONMENT=development
# mock (default), mps, cpu, or cloud-gpu
EXECUTION_PROFILE=mock
# Required only with cloud-gpu; the API rejects this outside production.
ALLOW_PAID_EXECUTION=false
ENABLE_LEGACY_SYNC_INFERENCE=false
JOB_TTL_SECONDS=86400
MAX_UPLOAD_BYTES=104857600
MAX_AUDIO_DURATION_SECONDS=600
TASK_SOFT_TIME_LIMIT_SECONDS=3300
TASK_TIME_LIMIT_SECONDS=3600
MOCK_JOB_SCENARIO=success
MOCK_JOB_DELAY_SECONDS=0

# Local development uses a shared directory/volume.
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=shared-storage

# Production S3-compatible storage:
# STORAGE_BACKEND=s3
# S3_BUCKET=echo
# S3_ENDPOINT_URL=https://s3.example.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
